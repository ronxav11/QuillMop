---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  onLight?: boolean;
  class?: string;
}

const { href, variant = "primary", onLight = false, class: className } = Astro.props;
---

{
  variant === "primary" ? (
    <a
      href={href}
      class:list={[
        "inline-block px-8 py-4 text-sm font-semibold uppercase tracking-wider transition-all duration-300",
        "bg-accent text-dark hover:bg-accent-hover",
        className,
      ]}
    >
      <slot />
    </a>
  ) : (
    <a
      href={href}
      class:list={[
        "inline-flex items-center gap-2 text-sm font-medium tracking-wide transition-colors duration-300",
        onLight ? "text-dark/70 hover:text-accent-hover" : "text-light/70 hover:text-accent",
        className,
      ]}
    >
      <slot />
    </a>
  )
}
