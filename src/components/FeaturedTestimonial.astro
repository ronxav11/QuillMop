---
import SectionLabel from "./SectionLabel.astro";
---

<section class="bg-light py-24 lg:py-32">
  <div class="mx-auto max-w-4xl px-6 text-center lg:px-8">
    <div data-animate>
      <SectionLabel text="What Our Clients Say" light />
    </div>

    <blockquote data-animate class="mt-10">
      <p
        class="font-display text-2xl leading-relaxed text-dark italic lg:text-4xl"
      >
        &ldquo;We hired Quillmop to clean up our blog. Three months later,
        organic traffic had tripled and our sales team was using our content in
        pitches. Game-changing.&rdquo;
      </p>
      <footer class="mt-10">
        <p class="text-base font-semibold text-accent-hover">Wale Larsen</p>
        <p class="mt-1 text-sm text-muted">
          Head of Marketing &middot; Vidal Towers
        </p>
      </footer>
    </blockquote>
  </div>
</section>
