---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { label: "Services", href: `${base}#services` },
  { label: "How It Works", href: `${base}#process` },
  { label: "Resources", href: `${base}resources` },
  { label: "Blog", href: `${base}blog` },
  { label: "About", href: `${base}about` },
  { label: "Get in Touch", href: `${base}contact` },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 z-50 w-full bg-white transition-all duration-300"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3 lg:px-8 lg:py-4"
  >
    <a href={base} class="flex-shrink-0">
      <img src={`${base}logo.png`} alt="Quillmop" class="h-14 w-auto lg:h-16" />
    </a>

    <div class="hidden items-center gap-10 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="group relative inline-block font-display text-base tracking-wide text-dark/60 origin-center transition-all duration-300 ease-out hover:text-dark hover:scale-[1.15]"
          >
            {link.label}
            <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-accent transition-all duration-300 group-hover:w-full" />
          </a>
        ))
      }
    </div>

    <button
      id="mobile-toggle"
      class="relative z-50 flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden"
      aria-label="Toggle menu"
    >
      <span
        class="block h-0.5 w-6 bg-dark transition-all duration-300"
        id="bar1"></span>
      <span
        class="block h-0.5 w-6 bg-dark transition-all duration-300"
        id="bar2"></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 flex translate-x-full flex-col items-center justify-center gap-8 bg-light transition-transform duration-500 ease-in-out md:hidden"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-link font-display text-3xl text-dark transition-colors duration-200 hover:text-accent-hover"
        >
          {link.label}
        </a>
      ))
    }
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  let open = false;

  function updateNavbar() {
    if (!navbar) return;
    if (window.scrollY > 40) {
      navbar.classList.add("shadow-md");
    } else {
      navbar.classList.remove("shadow-md");
    }
  }

  window.addEventListener("scroll", updateNavbar, { passive: true });
  updateNavbar();

  toggle?.addEventListener("click", () => {
    open = !open;
    if (open) {
      menu?.classList.remove("translate-x-full");
      menu?.classList.add("translate-x-0");
      bar1?.classList.add("rotate-45", "translate-y-[4px]");
      bar2?.classList.add("-rotate-45", "-translate-y-[4px]");
    } else {
      menu?.classList.add("translate-x-full");
      menu?.classList.remove("translate-x-0");
      bar1?.classList.remove("rotate-45", "translate-y-[4px]");
      bar2?.classList.remove("-rotate-45", "-translate-y-[4px]");
    }
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      open = false;
      menu?.classList.add("translate-x-full");
      menu?.classList.remove("translate-x-0");
      bar1?.classList.remove("rotate-45", "translate-y-[4px]");
      bar2?.classList.remove("-rotate-45", "-translate-y-[4px]");
    });
  });
</script>
