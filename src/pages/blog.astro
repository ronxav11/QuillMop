---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionLabel from "../components/SectionLabel.astro";
import Button from "../components/Button.astro";
const base = import.meta.env.BASE_URL;

const categories = [
  "All",
  "Content Marketing",
  "Digital Marketing",
  "SEO",
  "GEO",
  "AI",
  "Editing",
  "Strategy",
];
---

<Layout
  title="Blog — Quillmop"
  description="Insights on content marketing, SEO, AI content strategy, and more from the Quillmop team."
>
  <Navbar />
  <main>
    <section class="bg-dark pt-36 pb-24 lg:pb-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <SectionLabel text="The Quillmop Blog" />
        <h1
          class="mt-4 max-w-4xl font-display text-5xl text-light lg:text-7xl"
        >
          We clean up content for a living. Here&rsquo;s everything
          we&rsquo;ve learned along the way.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-light/50">
          We spend our days writing, editing, and fixing content for businesses
          across every industry. This is where we share what we&rsquo;re
          seeing, what&rsquo;s working, and what&rsquo;s quietly killing most
          brands&rsquo; content without them realising it.
        </p>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-light/50">
          Every week we&rsquo;re knee-deep in content strategies, SEO briefs,
          GEO tests, and AI experiments for our clients. This blog is where
          that work becomes lessons you can steal for your own business.
        </p>

        <div class="mt-10 max-w-md">
          <input
            type="text"
            placeholder="Search the blog..."
            class="w-full border border-border bg-dark-soft px-5 py-3 text-sm text-light outline-none transition-colors placeholder:text-muted focus:border-accent"
          />
        </div>
      </div>
    </section>

    <section class="bg-light py-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="flex flex-wrap gap-3">
          {
            categories.map((cat, i) => (
              <button
                class:list={[
                  "px-5 py-2 text-sm font-medium tracking-wide transition-all duration-200",
                  i === 0
                    ? "bg-dark text-light"
                    : "border border-border-light text-muted hover:border-dark hover:text-dark",
                ]}
              >
                {cat}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-light pb-24 lg:pb-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="border border-accent/30 bg-light-soft p-8 lg:p-12">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-accent"
            >Editor&rsquo;s Pick</span
          >
          <div class="mt-6 text-center">
            <p class="font-display text-2xl text-dark lg:text-3xl">
              Our first featured post is coming soon.
            </p>
            <p class="mt-3 text-base text-muted">
              Check back shortly for our editor&rsquo;s pick.
            </p>
          </div>
        </div>

        <div class="mt-16 py-16 text-center">
          <p class="font-display text-2xl text-dark">
            Nothing here yet, but we&rsquo;re working on it.
          </p>
          <p class="mt-3 text-base text-muted">
            Browse all posts or check back soon.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-dark py-24 lg:py-32">
      <div
        class="mx-auto max-w-3xl px-6 text-center lg:px-8"
      >
        <h2 class="font-display text-4xl text-light lg:text-5xl">
          Get the good stuff straight to your inbox.
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-light/50">
          Join businesses and marketers who get our best content from
          strategies, insights, and updates, delivered weekly. No spam.
          Unsubscribe anytime.
        </p>
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="mx-auto mt-10 flex max-w-lg flex-col gap-4 sm:flex-row"
        >
          <input
            type="hidden"
            name="access_key"
            value="76f303ff-d445-4888-b82b-c1dfda4ea053"
          />
          <input
            type="hidden"
            name="subject"
            value="New Blog Subscriber — Quillmop"
          />
          <input
            type="hidden"
            name="from_name"
            value="Quillmop Blog"
          />
          <input
            type="hidden"
            name="redirect"
            value="https://ronxav11.github.io/QuillMop/blog"
          />
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display:none"
          />
          <input
            type="email"
            name="email"
            required
            placeholder="Enter your email address"
            class="flex-1 border border-border bg-dark-soft px-5 py-3 text-sm text-light outline-none transition-colors placeholder:text-muted focus:border-accent"
          />
          <button
            type="submit"
            class="bg-accent px-8 py-3 text-sm font-semibold uppercase tracking-wider text-dark transition-all duration-300 hover:bg-accent-hover"
          >
            Subscribe Now
          </button>
        </form>
      </div>
    </section>

    <section class="bg-light py-24 text-center lg:py-32">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <h2 class="font-display text-4xl text-dark lg:text-5xl">
          Want us to create content like this for your business?
        </h2>
        <p class="mt-4 text-lg text-muted">
          We don&rsquo;t just write about great content, we produce it. See
          what Quillmop can do for your brand.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6">
          <Button href={`${base}services`}>See Our Services</Button>
          <Button href={`${base}contact`} variant="secondary" onLight
            >Get In Touch &rarr;</Button
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
