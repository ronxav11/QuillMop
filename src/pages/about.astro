---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionLabel from "../components/SectionLabel.astro";
import Button from "../components/Button.astro";
---

<Layout title="About — Quillmop" description="Learn about Quillmop and our approach to content and digital marketing.">
  <Navbar />
  <main>
    <section class="bg-dark pt-36 pb-24 lg:pb-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <SectionLabel text="About" />
        <h1 class="mt-4 max-w-4xl font-display text-5xl text-light lg:text-7xl">
          We believe every word should earn its place.
        </h1>
      </div>
    </section>

    <section class="bg-light py-24 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-16 lg:grid-cols-2">
          <div>
            <h2 class="font-display text-3xl text-dark lg:text-4xl">
              Content that means business
            </h2>
            <p class="mt-6 text-base leading-loose text-muted">
              Quillmop was founded on a simple frustration: too much content is
              being published that says nothing. Businesses invest in blogs that
              nobody reads, social posts that nobody engages with, and emails
              that nobody opens. Not because the ideas are bad — but because the
              execution doesn&rsquo;t match the ambition.
            </p>
            <p class="mt-4 text-base leading-loose text-muted">
              We exist to fix that. We&rsquo;re a content and digital marketing
              partner for businesses that take their words seriously. Every
              strategy we build, every piece we write, and every campaign we
              launch is tied to a measurable outcome. If it doesn&rsquo;t serve
              your goals, it doesn&rsquo;t ship.
            </p>
          </div>

          <div>
            <h2 class="font-display text-3xl text-dark lg:text-4xl">
              How we work
            </h2>
            <p class="mt-6 text-base leading-loose text-muted">
              We start every engagement by listening. We learn your business,
              your audience, your competitive landscape, and the specific
              outcomes you need from your content. Only then do we build the
              strategy and get to work.
            </p>
            <p class="mt-4 text-base leading-loose text-muted">
              Our team combines editorial craftsmanship with marketing strategy.
              We don&rsquo;t just write well — we write with purpose. And we
              track everything so you always know what your content is doing for
              your business.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-dark py-24 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-12 md:grid-cols-3">
          <div>
            <span class="font-display text-5xl text-accent">6</span>
            <p class="mt-2 text-sm font-medium uppercase tracking-wider text-light/50">
              Core services
            </p>
          </div>
          <div>
            <span class="font-display text-5xl text-accent">&infin;</span>
            <p class="mt-2 text-sm font-medium uppercase tracking-wider text-light/50">
              Commitment to quality
            </p>
          </div>
          <div>
            <span class="font-display text-5xl text-accent">0</span>
            <p class="mt-2 text-sm font-medium uppercase tracking-wider text-light/50">
              Tolerance for fluff
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-light py-24 text-center lg:py-32">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <h2 class="font-display text-4xl text-dark lg:text-5xl">
          Want to work together?
        </h2>
        <p class="mt-4 text-lg text-muted">
          The first conversation is free — and it might be the most valuable one
          your brand has this year.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6">
          <Button href="/contact">Get in Touch</Button>
          <Button href="/#services" variant="secondary"
            >See Our Services &rarr;</Button
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
