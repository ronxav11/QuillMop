---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import Button from "../../components/Button.astro";
const base = import.meta.env.BASE_URL;

const industries = [
  {
    title: "AI and Technology",
    slug: "ai-technology",
    description:
      "The AI space is crowded and moving fast. We help technology businesses communicate clearly enough to cut through it.",
  },
  {
    title: "Legal",
    slug: "legal",
    description:
      "Law firms have spent years building expertise. We make sure the right clients can find it, trust it, and act on it.",
  },
  {
    title: "Healthcare and Allied Health",
    slug: "healthcare",
    description:
      "From physiotherapists to private clinics, we help healthcare providers show up at the moment patients need them most.",
  },
  {
    title: "Professional Services",
    slug: "professional-services",
    description:
      "Accountants, consultants, and advisers sitting on extraordinary knowledge. We help them put it to work.",
  },
  {
    title: "Construction and Architecture",
    slug: "construction-architecture",
    description:
      "Remarkable work deserves to be seen beyond the projects that commissioned it. We build the content presence that makes that happen.",
  },
  {
    title: "Manufacturing and Industrial",
    slug: "manufacturing-industrial",
    description:
      "Long buying cycles reward businesses with a content presence. We build one for manufacturers that want to be found first.",
  },
];

const promises = [
  "No generic templates applied to your industry",
  "No writers who are learning your market on your time",
  "No content produced without a clear commercial purpose behind it",
];
---

<Layout
  title="Industries — Quillmop"
  description="We work exclusively with businesses in industries we understand deeply. Explore our industry expertise."
>
  <Navbar />
  <main>
    <section class="bg-dark pt-36 pb-24 lg:pb-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <SectionLabel text="Industries" />
        <h1
          class="mt-4 max-w-4xl font-display text-5xl text-light lg:text-7xl"
        >
          We don&rsquo;t do generic.<br />We do your industry.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-light/50">
          Every industry has its own language, its own buyers, and its own
          content challenges. Generic marketing advice doesn&rsquo;t cut it. We
          work exclusively with businesses in industries we understand deeply,
          so every word we write is built around the specific realities of your
          market.
        </p>
      </div>
    </section>

    <section class="bg-light py-24 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <SectionLabel text="Where We Work" light />
        <h2 class="mt-4 font-display text-4xl text-dark lg:text-5xl">
          Six industries. Deep expertise. Real results.
        </h2>

        <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            industries.map((ind) => (
              <a
                href={`${base}industries/${ind.slug}`}
                class="group block border border-border-light/20 bg-light-soft p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-dark/5 lg:p-10"
              >
                <h3 class="font-display text-2xl text-dark transition-colors duration-300 group-hover:text-accent-hover">
                  {ind.title}
                </h3>
                <p class="mt-4 text-sm leading-relaxed text-muted">
                  {ind.description}
                </p>
                <span class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors group-hover:text-accent-hover">
                  Explore {ind.title} &rarr;
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-dark py-24 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <SectionLabel text="The Quillmop Difference" />
        <h2
          class="mt-4 max-w-4xl font-display text-4xl text-light lg:text-5xl"
        >
          A content agency that doesn&rsquo;t know your industry is making
          educated guesses at best.
        </h2>
        <p class="mt-6 max-w-3xl text-base leading-loose text-light/50">
          Most content agencies write for everyone, which means they write for
          no one particularly well. They learn your industry on your time,
          produce content that sounds plausible but misses the nuance, and move
          on to the next client.
        </p>
        <p class="mt-4 max-w-3xl text-base leading-loose text-light/50">
          We work differently. Every industry we serve is one we have spent
          time understanding from the inside from the buyers, the buying
          process, the language that builds trust, and the content that actually
          drives decisions. When we write for your business, we&rsquo;re not
          starting from scratch. We&rsquo;re starting from a position of
          genuine knowledge.
        </p>
      </div>
    </section>

    <section class="bg-light py-24 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <SectionLabel text="Our Promise" light />
        <h2
          class="mt-4 max-w-3xl font-display text-4xl text-dark lg:text-5xl"
        >
          The industry changes. The standard doesn&rsquo;t.
        </h2>
        <p class="mt-6 max-w-3xl text-base leading-loose text-muted">
          No matter which industry you&rsquo;re in, every engagement with
          Quillmop starts the same way, with a deep understanding of your
          business, your buyers, and your goals. And ends the same way too with
          content that is sharp, strategic, and built to perform.
        </p>

        <ul class="mt-8 space-y-4">
          {
            promises.map((p) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 text-accent font-semibold">&#10005;</span>
                <span class="text-base text-dark/80">{p}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="bg-dark py-24 text-center lg:py-32">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <SectionLabel text="Not Sure Where You Fit?" />
        <h2 class="mt-4 font-display text-4xl text-light lg:text-5xl">
          Your industry shapes everything about how we work with you.
          Let&rsquo;s start there.
        </h2>
        <p class="mt-4 text-lg text-light/50">
          If your industry isn&rsquo;t listed here, get in touch anyway. If we
          can serve you well, we&rsquo;ll tell you. If we can&rsquo;t,
          we&rsquo;ll tell you that too.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6">
          <Button href={`${base}contact`}>Get In Touch</Button>
          <Button href={`${base}#services`} variant="secondary"
            >See Our Services &rarr;</Button
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
