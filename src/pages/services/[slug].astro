---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import Button from "../../components/Button.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { title, description, longDescription, includes } = service.data;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${title} — Quillmop`} description={description}>
  <Navbar />
  <main>
    <section class="bg-dark pt-36 pb-24 lg:pb-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <a
          href={`${base}services`}
          class="inline-flex items-center gap-2 text-sm text-muted transition-colors hover:text-accent"
        >
          &larr; All Services
        </a>

        <SectionLabel text="Service" />
        <h1
          class="mt-4 max-w-4xl font-display text-5xl text-light lg:text-7xl"
        >
          {title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-light/50">
          {description}
        </p>
      </div>
    </section>

    <section class="bg-light py-24 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-16 lg:grid-cols-5">
          <div class="lg:col-span-3">
            <h2 class="font-display text-3xl text-dark">The full picture</h2>
            <p class="mt-6 text-base leading-loose text-muted">
              {longDescription}
            </p>
          </div>

          <div class="lg:col-span-2">
            <h3
              class="text-xs font-semibold uppercase tracking-[0.2em] text-muted"
            >
              What&rsquo;s included
            </h3>
            <div class="mt-6 space-y-6">
              {
                includes.map((item) => (
                  <div class="border-l-2 border-accent pl-6">
                    <h4 class="font-semibold text-dark">{item.name}</h4>
                    <p class="mt-1 text-sm leading-relaxed text-muted">
                      {item.detail}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-dark py-24 text-center lg:py-32">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <h2 class="font-display text-4xl text-light lg:text-5xl">
          Ready to get started?
        </h2>
        <p class="mt-4 text-lg text-light/50">
          Let&rsquo;s talk about how {title.toLowerCase()} can work for your business.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6">
          <Button href={`${base}contact`}>Get in Touch</Button>
          <Button href={`${base}services`} variant="secondary"
            >&larr; View All Services</Button
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
